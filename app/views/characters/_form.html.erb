<%= form_with(model: character, html: { class: "character-form" }) do |form| %>
  <% if character.errors.any? %>
    <div class="form-errors">
      <strong><%= pluralize(character.errors.count, "error") %> prohibited this character from being saved:</strong>
      <ul>
        <% character.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <fieldset>
    <legend>Identity</legend>
    <div class="field-row">
      <div class="field field-wide">
        <%= form.label :name %>
        <%= form.text_field :name %>
      </div>
      <div class="field">
        <%= form.label :title %>
        <%= form.text_field :title %>
      </div>
    </div>
    <div class="field-row">
      <div class="field">
        <%= form.label :character_class %>
        <%= form.text_field :character_class %>
      </div>
      <div class="field">
        <%= form.label :class_type %>
        <%= form.text_field :class_type %>
      </div>
      <div class="field field-narrow">
        <%= form.label :level %>
        <%= form.number_field :level %>
      </div>
      <div class="field field-narrow">
        <%= form.label :template %>
        <%= form.number_field :template %>
      </div>
    </div>
  </fieldset>

  <fieldset>
    <legend>Ability Scores</legend>
    <div class="stat-grid">
      <% %i[str int wil dex con cha].each do |stat| %>
        <div class="field">
          <%= form.label stat %>
          <%= form.number_field stat %>
        </div>
      <% end %>
    </div>
  </fieldset>

  <fieldset>
    <legend>Description</legend>
    <div class="field-row">
      <div class="field">
        <%= form.label :ethnicity %>
        <%= form.text_field :ethnicity %>
      </div>
      <div class="field field-narrow">
        <%= form.label :sex %>
        <%= form.text_field :sex %>
      </div>
      <div class="field">
        <%= form.label :alignment %>
        <%= form.text_field :alignment %>
      </div>
    </div>
    <div class="field-row">
      <div class="field">
        <%= form.label :build %>
        <%= form.text_field :build %>
      </div>
      <div class="field field-narrow">
        <%= form.label :height_inches, "Height (in)" %>
        <%= form.number_field :height_inches %>
      </div>
      <div class="field field-narrow">
        <%= form.label :weight_lbs, "Weight (lbs)" %>
        <%= form.number_field :weight_lbs %>
      </div>
    </div>
  </fieldset>

  <fieldset>
    <legend>Appearance</legend>
    <div class="field-row">
      <div class="field">
        <%= form.label :eye_color %>
        <%= form.text_field :eye_color %>
      </div>
      <div class="field">
        <%= form.label :skin_color %>
        <%= form.text_field :skin_color %>
      </div>
      <div class="field">
        <%= form.label :hair_color %>
        <%= form.text_field :hair_color %>
      </div>
      <div class="field">
        <%= form.label :hair_texture %>
        <%= form.text_field :hair_texture %>
      </div>
    </div>
  </fieldset>

  <fieldset>
    <legend>Features</legend>
    <div class="field-row">
      <div class="field field-wide">
        <%= form.textarea :features, rows: 3 %>
      </div>
    </div>
  </fieldset>

  <div class="form-actions">
    <%= form.submit %>
    <%= form.submit "Generate", formaction: generate_characters_path, formmethod: "post", class: "btn btn-secondary" %>
    <%= link_to "Back to characters", characters_path, class: "btn btn-secondary" %>
  </div>
<% end %>
